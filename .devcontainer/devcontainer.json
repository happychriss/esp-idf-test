{
  "name": "Claude Code Dev Container",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  "remoteUser": "ubuntu",
  "updateRemoteUserUID": true,
  "customizations": {
    "vscode": {
      "extensions": [
        "Anthropic.claude-code"
      ]
    }
  },
  "forwardPorts": [],
  "mounts": [
    "source=devcontainer-commandhistory,target=/commandhistory,type=volume"
  ]
}
